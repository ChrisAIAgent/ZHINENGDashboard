# Gmail OAuth 2.0 凭据模板
# 复制本文件为 .env 并填入真实值（.env 已被 .gitignore 忽略，不会提交）
#
# 获取方式：Google Cloud Console → APIs & Services → Credentials
#   → Create Credentials → OAuth client ID（应用类型选 Web application）
#   → 重定向 URI 填 http://localhost:8787/oauth/callback

# OAuth Client ID（必填）
GMAIL_CLIENT_ID=63620858892-nhh60md34v0tqvscj1huhiuqjo294v8l.apps.googleusercontent.com

# OAuth Client Secret（Web 应用类型必填；若为桌面应用类型可留空，脚本自动改用 PKCE）
GMAIL_CLIENT_SECRET=

# 回调地址（需与 Google Cloud 中注册的 Authorized redirect URI 完全一致）
GMAIL_REDIRECT_URI=http://localhost:8787/oauth/callback

# 申请的范围（默认只读，足够拉取邮件做看板）
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly

# refresh_token 加密密钥（首次运行 gmail-oauth-setup.mjs 会自动生成并写回本文件，无需手动填）
# GMAIL_ENC_KEY=
